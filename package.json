{
  "name": "lero-lero-valfenda",
  "version": "0.1.0",
  "description": "Gerador de lero-lero e reprimendas eruditas de Valfenda usando IA local",
  "author": "Elrond de Valfenda <elrond@valfenda.org>",
  "homepage": "https://github.com/valfenda/lero-lero-valfenda",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron:start": "electron .",
    "electron:dev": "concurrently -n \"api,vite,electron\" -c \"blue,green,magenta\" \"npm run dev:api\" \"vite --host 127.0.0.1\" \"NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.valfenda.lerolero",
    "productName": "Lero Lero de Valfenda",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
